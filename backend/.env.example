# Backend environment — copy this file to `.env` in the same folder as `index.js`.
# Values are read on server start via `loadEnv.js`.

# --- Server ---
PORT=3000

# --- Database (SQLite) ---
# Omit DB_PATH to use the default file: <backend>/data/qr.db
# If set: absolute path as-is; relative path is resolved from this backend folder (project root)
# DB_PATH=./data/qr.db
# DB_TIMEOUT_MS=5000

# --- Crypto ---
# Required in production. Used for HMAC-SHA256 QR tokens.
# QR_TOKEN_SECRET=
